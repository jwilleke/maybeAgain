# To enable / disable self-hosting features.
SELF_HOSTED=false

# Enable Synth market data (careful, this will use your API credits)
SYNTH_API_KEY=yourapikeyhere

# Security price provider: "synth" (default) or "alpha_vantage"
# Alpha Vantage free tier: 25 requests/day, 5 requests/minute
# Get a free API key at https://www.alphavantage.co/support/#api-key
SECURITY_PROVIDER=synth
ALPHA_VANTAGE_API_KEY=
